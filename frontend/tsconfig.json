{
  "compilerOptions": {
    /* Language & module */
    "target": "esnext",
    "lib": [ "dom", "dom.iterable", "esnext" ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": [ "vite/client", "node" ],

    /* Interop */
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Type checking */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,

    /* Build behaviour (Vite handles emit) */
    "noEmit": true,

    /* Absolute imports like '@/components/Button' */
    "baseUrl": "src",
    "paths": {
      "@/*": [ "*" ]
    },

    /* Ensure local d.ts files are picked up */
    "typeRoots": [ "./node_modules/@types", "./src/types" ]
  },

  /* Only include frontend code */
  "include": [ "src/**/*", "src/vite-env.d.ts" ],

  /* Never compile backend files from the client build */
  "exclude": [ "../src/**", "../server/**", "../api/**", "../backend/**", "node_modules" ],

  /* NEW: tell TS there's a separate Node config for vite.config.ts */
  "references": [ { "path": "./tsconfig.node.json" } ]
}
