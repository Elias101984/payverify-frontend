{
  "compilerOptions": {
    /* Language and Environment */
    "target": "ES6",
    "module": "commonjs",
    "lib": [ "ES6" ],
    "moduleResolution": "node",

    /* Types setup */
    "typeRoots": [ "./node_modules/@types", "./src/types" ],
    "types": [ "node", "jest" ],

    /* Interop and Compatibility */
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": [ "src/*" ],
      "controllers/*": [ "src/controllers/*" ],
      "models/*": [ "src/models/*" ],
      "middlewares/*": [ "src/middlewares/*" ],
      "config/*": [ "src/config/*" ]
    },

    /* Build Output */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Type Checking */
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* Debugging */
    "sourceMap": true
  },

  /* Files to Include */
  "include": [ "src", "test" ],

  /* Files to Exclude */
  "exclude": [ "node_modules", "dist" ]
}
